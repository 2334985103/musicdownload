<Window x:Class="网易云音乐下载.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:网易云音乐下载"
        xmlns:models="clr-namespace:网易云音乐下载.Models"
        xmlns:vm="clr-namespace:网易云音乐下载.ViewModels"
        mc:Ignorable="d"
        Title="MusicBox"
        Height="750"
        Width="1200"
        MinHeight="650"
        MinWidth="900"
        Background="#FFF5F5F7"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextHintingMode="Auto"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="-apple-system, BlinkMacSystemFont, Segoe UI, PingFang SC, Microsoft YaHei, sans-serif">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- macOS 风格颜色资源 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF007AFF"/>
        <SolidColorBrush x:Key="PrimaryLightColor" Color="#FF3395FF"/>
        <SolidColorBrush x:Key="PrimaryDarkColor" Color="#FF0056CC"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#FFF5F5F7"/>
        <SolidColorBrush x:Key="CardBackgroundColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#FF1D1D1F"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#FF86868B"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FFE5E5EA"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#FF34C759"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFFF9500"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#FFFF3B30"/>
        <SolidColorBrush x:Key="SidebarBackgroundColor" Color="#FFF5F5F7"/>
        <SolidColorBrush x:Key="SidebarHoverColor" Color="#FFE8E8ED"/>
        <SolidColorBrush x:Key="SidebarSelectedColor" Color="#FFE0E0E6"/>
        <SolidColorBrush x:Key="GlassBackgroundColor" Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="PlayerBackgroundColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SecondaryButtonColor" Color="#FF5856D6"/>

        <!-- macOS 风格按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryLightColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FFBDBDBD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackgroundColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarSelectedColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryLightColor}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.3" Color="#FF007AFF"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格侧边栏导航按钮样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="8,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontSize="16"
                                           FontFamily="Segoe UI Emoji"/>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarSelectedColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格文本框样式 -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS 风格单选按钮样式 -->
        <Style x:Key="ModernRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="radioBorder"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1.5"
                                    Background="White">
                                <Ellipse x:Name="radioCheck"
                                         Width="8"
                                         Height="8"
                                         Fill="{StaticResource PrimaryColor}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="radioBorder" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="radioCheck" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundColor}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="0"
                                      BlurRadius="20"
                                      Opacity="0.08"
                                      Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#FFE5E5EA"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <Grid>
                                <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                                <Rectangle x:Name="PART_Indicator"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="3" RadiusY="3"
                                           HorizontalAlignment="Left"
                                           Width="0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 布尔转可见性转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 布尔值取反转可见性转换器 -->
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- 布尔值取反转转换器 -->
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- 输入模式转换器 -->
        <local:InputModeConverter x:Key="InputModeConverter"/>

        <!-- 整数转布尔值转换器 -->
        <local:IntToBoolConverter x:Key="IntToBoolConverter"/>

        <!-- 整数转可见性转换器 -->
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <!-- 布尔值转背景色转换器 -->
        <local:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>

        <!-- TimeSpan 转秒数转换器 -->
        <local:TimeSpanToSecondsConverter x:Key="TimeSpanToSecondsConverter"/>

        <!-- 布尔值转播放/暂停图标转换器 -->
        <local:BoolToPlayPauseConverter x:Key="BoolToPlayPauseConverter"/>

        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="#FFE5E5EA"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Rectangle x:Name="PART_Track"
                                       Height="4"
                                       Fill="{TemplateBinding Background}"
                                       RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="PART_SelectionRange"
                                       Height="4"
                                       Fill="{TemplateBinding Foreground}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"/>
                            <Thumb x:Name="PART_Thumb"
                                   Width="14" Height="14"
                                   Background="White"
                                   BorderBrush="{StaticResource PrimaryColor}"
                                   BorderThickness="0"
                                   VerticalAlignment="Center">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Ellipse Fill="{TemplateBinding Background}"
                                                 Stroke="{TemplateBinding BorderBrush}"
                                                 StrokeThickness="{TemplateBinding BorderThickness}">
                                            <Ellipse.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.2" Color="#000000"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口标题栏按钮样式 -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse x:Name="ellipse"
                                 Fill="{TemplateBinding Background}"
                                 Width="{TemplateBinding Width}"
                                 Height="{TemplateBinding Height}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ellipse" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundColor}" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource GlassBackgroundColor}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Background="#FFFF5F57"
                                Click="CloseButton_Click"
                                ToolTip="关闭"/>
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Background="#FFFEbc2E"
                                Margin="8,0,0,0"
                                Click="MinimizeButton_Click"
                                ToolTip="最小化"/>
                        <Button Style="{StaticResource WindowButtonStyle}"
                                Background="#FF28C840"
                                Margin="8,0,0,0"
                                Click="MaximizeButton_Click"
                                ToolTip="最大化"/>
                    </StackPanel>

                    <!-- 窗口标题 -->
                    <TextBlock Grid.Column="1"
                               Text="MusicBox"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryColor}"/>

                    <!-- 右侧占位 -->
                    <Border Grid.Column="2" Width="80"/>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧边栏 -->
                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBackgroundColor}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 应用标题 -->
                        <Border Grid.Row="0"
                                Padding="20,20"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource PrimaryColor}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="♪"
                                               FontSize="22"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="MusicBox"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryColor}"/>
                                    <TextBlock Text="音乐播放器"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryColor}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 导航菜单 -->
                        <StackPanel Grid.Row="1" Margin="0,16">
                            <TextBlock Text="功能菜单"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryColor}"
                                       Margin="20,0,0,8"
                                       Opacity="0.8"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Content="NCM 转换"
                                         Tag="🔄"
                                         IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Content="ID 下载"
                                         Tag="⬇️"
                                         IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"/>

                            <RadioButton Style="{StaticResource SidebarButtonStyle}"
                                         Content="我的歌单"
                                         Tag="🎵"
                                         IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"/>
                        </StackPanel>

                        <!-- 底部信息 -->
                        <Border Grid.Row="2"
                                Padding="20"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,1,0,0">
                            <TextBlock Text="© 2024 MusicBox"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryColor}"
                                       Opacity="0.7"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 主内容区 -->
                <Grid Grid.Column="1" Background="{StaticResource BackgroundColor}">
                    <!-- NCM 转换页面 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28"
                                  Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=0}">
                        <StackPanel>
                            <!-- 页面标题 -->
                            <TextBlock Text="NCM 转换"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryColor}"
                                       Margin="0,0,0,24"/>

                            <!-- 输入模式选择卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="输入模式"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="单文件"
                                                     Style="{StaticResource ModernRadioButtonStyle}"
                                                     IsChecked="{Binding InputMode, Converter={StaticResource InputModeConverter}, ConverterParameter=SingleFile}"/>
                                        <RadioButton Content="批量文件夹"
                                                     Style="{StaticResource ModernRadioButtonStyle}"
                                                     IsChecked="{Binding InputMode, Converter={StaticResource InputModeConverter}, ConverterParameter=BatchFolder}"/>
                                        <RadioButton Content="多文件选择"
                                                     Style="{StaticResource ModernRadioButtonStyle}"
                                                     IsChecked="{Binding InputMode, Converter={StaticResource InputModeConverter}, ConverterParameter=MultipleFiles}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 输入路径卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="输入路径"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True"
                                                 Margin="0,0,12,0"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="浏览..."
                                                Command="{Binding BrowseInputCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 输出设置卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="输出设置"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True"
                                                 Margin="0,0,12,0"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="浏览..."
                                                Command="{Binding BrowseOutputCommand}"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="输出格式:"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <ComboBox Width="120"
                                                  SelectedItem="{Binding OutputFormat}"
                                                  Padding="10,8"
                                                  BorderBrush="{StaticResource BorderColor}"
                                                  Background="White">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBoxItem Content="MP3" IsSelected="True"/>
                                            <ComboBoxItem Content="FLAC"/>
                                            <ComboBoxItem Content="WAV"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 文件列表卡片 -->
                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding NcmFiles.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="待转换文件"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource IconButtonStyle}"
                                                Content="✕"
                                                ToolTip="清空列表"
                                                Command="{Binding ClearFilesCommand}"/>
                                    </Grid>

                                    <Border BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            MaxHeight="200">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding NcmFiles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FFF9F9F9"
                                                                CornerRadius="8"
                                                                Padding="12,10"
                                                                Margin="8,5">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding FileName}"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Text="{Binding FileSizeText}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondaryColor}"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding StatusText}"
                                                                           Foreground="{StaticResource PrimaryColor}"
                                                                           Margin="12,0"
                                                                           VerticalAlignment="Center"/>
                                                                <Button Grid.Column="2"
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Content="✕"
                                                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 转换控制卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0"
                                                     Style="{StaticResource ModernProgressBarStyle}"
                                                     Value="{Binding ConversionProgress}"
                                                     Maximum="100"
                                                     Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ConversionProgress, StringFormat='{}{0}%'}"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowConversionComplete}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <TextBlock Text="{Binding ConversionStatusText}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryColor}"
                                               Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Content="开始转换"
                                                Command="{Binding StartConversionCommand}"
                                                Margin="0,0,12,0"/>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="取消"
                                                Command="{Binding CancelConversionCommand}"/>
                                    </StackPanel>

                                    <Grid Visibility="{Binding ShowConversionComplete, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Margin="0,16,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Width="24"
                                                    Height="24"
                                                    CornerRadius="12"
                                                    Background="{StaticResource SuccessColor}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="✓"
                                                           FontSize="14"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="转换完成！"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessColor}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 转换完成后的导入歌单选项 -->
                                    <Border Visibility="{Binding ShowImportToPlaylistOptions, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{StaticResource SidebarSelectedColor}"
                                            CornerRadius="10"
                                            Padding="16"
                                            Margin="0,16,0,0"
                                            BorderBrush="{StaticResource PrimaryColor}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="🎵 转换完成！是否将歌曲导入歌单？"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryColor}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,12"/>
                                            <TextBlock Text="{Binding ConvertedFiles.Count, StringFormat='共 {0} 首歌曲'}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryColor}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,16"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                                        Content="导入现有歌单"
                                                        Command="{Binding ImportToExistingPlaylistCommand}"
                                                        Margin="0,0,12,0"/>
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="创建新歌单"
                                                        Command="{Binding ImportToNewPlaylistCommand}"
                                                        Margin="0,0,12,0"/>
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="暂不导入"
                                                        Command="{Binding SkipImportToPlaylistCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ID 下载页面 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28"
                                  Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=1}">
                        <StackPanel>
                            <!-- 页面标题 -->
                            <TextBlock Text="ID 下载"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryColor}"
                                       Margin="0,0,0,24"/>

                            <!-- 歌曲 ID 输入卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="歌曲 ID(此功能还在开发中暂不可用)"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>
                                    <TextBlock Text="输入网易云音乐歌曲 ID（纯数字）"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryColor}"
                                               Margin="0,0,0,8"/>
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                             Text="{Binding SongId, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- 输出设置卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="输出设置"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>

                                    <CheckBox Content="使用与 NCM 转换相同的输出路径"
                                              IsChecked="{Binding UseSameOutputPath}"
                                              Margin="0,0,0,12"/>

                                    <Grid IsEnabled="{Binding UseSameOutputPath, Converter={StaticResource InverseBoolConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Text="{Binding DownloadOutputPath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True"
                                                 Margin="0,0,12,0"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="浏览..."
                                                Command="{Binding BrowseDownloadOutputCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 下载控制卡片 -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0"
                                                     Style="{StaticResource ModernProgressBarStyle}"
                                                     Value="{Binding DownloadProgress}"
                                                     Maximum="100"
                                                     Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DownloadProgress, StringFormat='{}{0}%'}"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowDownloadComplete}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <TextBlock Text="{Binding DownloadStatusText}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryColor}"
                                               Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Content="开始下载"
                                                Command="{Binding StartDownloadCommand}"
                                                Margin="0,0,12,0"/>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="取消"
                                                Command="{Binding CancelDownloadCommand}"/>
                                    </StackPanel>

                                    <Grid Visibility="{Binding ShowDownloadComplete, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Margin="0,16,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Width="24"
                                                    Height="24"
                                                    CornerRadius="12"
                                                    Background="{StaticResource SuccessColor}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="✓"
                                                           FontSize="14"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="下载完成！"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessColor}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 下载任务列表 -->
                            <Border Style="{StaticResource CardStyle}"
                                    Visibility="{Binding DownloadTasks.Count, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="下载任务"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"/>

                                    <Border BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            MaxHeight="200">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding DownloadTasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FFF9F9F9"
                                                                CornerRadius="8"
                                                                Padding="12,10"
                                                                Margin="8,5">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding SongName}"
                                                                               FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Artist}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondaryColor}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <ProgressBar Value="{Binding Progress}"
                                                                                Maximum="100"
                                                                                Width="80"
                                                                                Height="6"
                                                                                Margin="0,0,8,0"/>
                                                                    <TextBlock Text="{Binding StatusText}"
                                                                               Foreground="{StaticResource PrimaryColor}"
                                                                               VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 我的歌单页面 -->
                    <Grid Visibility="{Binding SelectedTabIndex, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=2}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 歌单列表页面 -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="28"
                                      Visibility="{Binding IsPlaylistDetailView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel>
                                <!-- 页面标题 -->
                                <TextBlock Text="我的歌单"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryColor}"
                                           Margin="0,0,0,24"/>

                                <!-- 歌单存储目录设置卡片 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="歌单存储目录"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding PlaylistsBaseDirectory}"
                                                     IsReadOnly="True"
                                                     Margin="0,0,12,0"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="更改目录"
                                                    Command="{Binding BrowsePlaylistsDirectoryCommand}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- 创建歌单卡片 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="创建新歌单"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     Text="{Binding NewPlaylistName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,12,0"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="选择封面"
                                                    Command="{Binding BrowsePlaylistCoverCommand}"
                                                    Margin="0,0,8,0"/>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Content="创建歌单"
                                                    Command="{Binding CreatePlaylistCommand}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding NewPlaylistCoverPath, StringFormat='已选择封面: {0}'}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryColor}"
                                                   Margin="0,8,0,0"
                                                   Visibility="{Binding NewPlaylistCoverPath, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 歌单列表卡片 -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="歌单列表"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Playlists.Count, StringFormat='{}{0} 个歌单'}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryColor}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <Border BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                MaxHeight="280">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding Playlists}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}, FallbackValue=#FFF9F9F9}"
                                                                    CornerRadius="8"
                                                                    Padding="12,10"
                                                                    Margin="8,5"
                                                                    BorderBrush="{StaticResource BorderColor}"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftClick"
                                                                                  Command="{Binding DataContext.SelectPlaylistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                  CommandParameter="{Binding}"/>
                                                                </Border.InputBindings>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 封面 -->
                                                                    <Border Grid.Column="0"
                                                                            Width="52"
                                                                            Height="52"
                                                                            CornerRadius="6"
                                                                            Margin="0,0,12,0"
                                                                            Background="{StaticResource SidebarSelectedColor}"
                                                                            ClipToBounds="True">
                                                                        <Image Source="{Binding CoverImage}"
                                                                               Stretch="UniformToFill"
                                                                               Visibility="{Binding HasCustomCover, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="14"/>
                                                                        <TextBlock Text="{Binding SongCountText}"
                                                                                   FontSize="12"
                                                                                   Foreground="{StaticResource TextSecondaryColor}"
                                                                                   Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                                Content="▶"
                                                                                FontSize="12"
                                                                                ToolTip="进入歌单"
                                                                                Command="{Binding DataContext.OpenPlaylistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                                Content="📂"
                                                                                ToolTip="更改目录"
                                                                                Command="{Binding DataContext.ChangePlaylistDirectoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                                Content="📁"
                                                                                ToolTip="打开文件夹"
                                                                                Command="{Binding DataContext.BrowsePlaylistFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                                Content="✕"
                                                                                ToolTip="删除歌单"
                                                                                Command="{Binding DataContext.DeletePlaylistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 选中歌单的详细信息卡片 -->
                                <Border Style="{StaticResource CardStyle}"
                                        Visibility="{Binding SelectedPlaylist, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <!-- 歌单标题和封面 -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 大封面 -->
                                            <Border Grid.Column="0"
                                                    Width="88"
                                                    Height="88"
                                                    CornerRadius="10"
                                                    Margin="0,0,16,0"
                                                    Background="{StaticResource SidebarSelectedColor}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding SelectedPlaylist.CoverImage}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding SelectedPlaylist.HasCustomCover, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedPlaylist.Name}"
                                                           FontSize="22"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding SelectedPlaylist.SongCountText}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding SelectedPlaylist.CreatedTimeText, StringFormat='创建于: {0}'}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="更改封面"
                                                        Command="{Binding SetPlaylistCoverCommand}"
                                                        Margin="0,0,8,0"/>
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="恢复默认"
                                                        Command="{Binding RemovePlaylistCoverCommand}"
                                                        Visibility="{Binding SelectedPlaylist.HasCustomCover, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 操作按钮 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                                    Content="添加歌曲"
                                                    Command="{Binding AddSongToPlaylistCommand}"
                                                    Margin="0,0,8,0"/>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="添加转换文件"
                                                    Command="{Binding AddConvertedFilesToPlaylistCommand}"
                                                    Margin="0,0,8,0"/>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="重命名"
                                                    Command="{Binding RenamePlaylistCommand}"/>
                                        </StackPanel>

                                        <!-- 歌曲列表 -->
                                        <TextBlock Text="歌曲列表"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,12"/>

                                        <Border BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                MaxHeight="350">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SelectedPlaylist.Songs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FFF9F9F9"
                                                                    CornerRadius="8"
                                                                    Padding="12,10"
                                                                    Margin="8,5">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 播放按钮 -->
                                                                    <Button Grid.Column="0"
                                                                            Style="{StaticResource CircleButtonStyle}"
                                                                            Width="32"
                                                                            Height="32"
                                                                            Content="▶"
                                                                            FontSize="10"
                                                                            ToolTip="播放"
                                                                            Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Margin="0,0,10,0"/>
                                                                    <!-- 歌曲信息 -->
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="13"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding ArtistText}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource TextSecondaryColor}"/>
                                                                    </StackPanel>
                                                                    <!-- 时长 -->
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding DurationText}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondaryColor}"
                                                                               Margin="12,0"
                                                                               VerticalAlignment="Center"
                                                                               Width="45"/>
                                                                    <!-- 文件大小 -->
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding FileSizeText}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextSecondaryColor}"
                                                                               Margin="12,0"
                                                                               VerticalAlignment="Center"
                                                                               Width="65"/>
                                                                    <!-- 删除按钮 -->
                                                                    <Button Grid.Column="4"
                                                                            Style="{StaticResource IconButtonStyle}"
                                                                            Content="🗑"
                                                                            FontSize="14"
                                                                            ToolTip="删除歌曲"
                                                                            Command="{Binding DataContext.RemoveSongFromPlaylistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 状态文本 -->
                                <TextBlock Text="{Binding PlaylistStatusText}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryColor}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 歌单详情页面 -->
                        <Grid Grid.Row="0"
                              Visibility="{Binding IsPlaylistDetailView, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 顶部导航栏 -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource CardBackgroundColor}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 返回按钮 -->
                                    <Button Grid.Column="0"
                                            Style="{StaticResource IconButtonStyle}"
                                            Content="←"
                                            FontSize="18"
                                            Width="36"
                                            Height="36"
                                            ToolTip="返回歌单列表"
                                            Command="{Binding GoBackToPlaylistsCommand}"
                                            Margin="0,0,16,0"/>

                                    <!-- 歌单标题 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PlaylistDetailPlaylist.Name}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryColor}"/>
                                        <TextBlock Text="{Binding PlaylistDetailPlaylist.SongCountText}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryColor}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="添加歌曲"
                                                Command="{Binding AddSongToPlaylistCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="更改目录"
                                                Command="{Binding ChangePlaylistDirectoryCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="更改封面"
                                                Command="{Binding SetPlaylistCoverCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="📁"
                                                ToolTip="打开文件夹"
                                                Command="{Binding BrowsePlaylistFolderCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 歌曲列表 -->
                            <Border Grid.Row="1"
                                    Background="{StaticResource BackgroundColor}"
                                    Padding="20">
                                <Border BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding PlaylistDetailPlaylist.Songs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFF9F9F9"
                                                            CornerRadius="8"
                                                            Padding="12,10"
                                                            Margin="8,5"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                                                        <Setter Property="Background" Value="White"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 播放按钮 -->
                                                            <Button Grid.Column="0"
                                                                    Style="{StaticResource CircleButtonStyle}"
                                                                    Width="32"
                                                                    Height="32"
                                                                    Content="▶"
                                                                    FontSize="10"
                                                                    ToolTip="播放"
                                                                    Command="{Binding DataContext.PlaySongCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,10,0"/>

                                                            <!-- 歌曲信息 -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="300"/>
                                                                <TextBlock Text="{Binding ArtistText}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryColor}"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>

                                                            <!-- 文件大小 -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding FileSizeText}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryColor}"
                                                                       VerticalAlignment="Center"
                                                                       Width="55"
                                                                       TextAlignment="Center"
                                                                       Margin="12,0,0,0"/>

                                                            <!-- 分隔线 -->
                                                            <Rectangle Grid.Column="3"
                                                                       Width="1"
                                                                       Height="20"
                                                                       Fill="{StaticResource BorderColor}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"/>

                                                            <!-- 时长 -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding DurationText}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryColor}"
                                                                       VerticalAlignment="Center"
                                                                       Width="50"
                                                                       TextAlignment="Center"
                                                                       Margin="12,0,0,0"/>

                                                            <!-- 分隔线 -->
                                                            <Rectangle Grid.Column="5"
                                                                       Width="1"
                                                                       Height="20"
                                                                       Fill="{StaticResource BorderColor}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="12,0,0,0"/>

                                                            <!-- 删除按钮 -->
                                                            <Button Grid.Column="6"
                                                                    Style="{StaticResource IconButtonStyle}"
                                                                    Content="🗑"
                                                                    FontSize="14"
                                                                    ToolTip="删除歌曲"
                                                                    Command="{Binding DataContext.RemoveSongFromPlaylistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="12,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Border>
                        </Grid>

                        <!-- 音乐播放器 - 固定在底部 -->
                        <Border Grid.Row="1"
                                Background="{StaticResource PlayerBackgroundColor}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,1,0,0"
                                Visibility="{Binding IsPlayerVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Padding="20,12">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.1" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 歌曲信息 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="6"
                                            Background="{StaticResource SidebarSelectedColor}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="🎵"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="正在播放"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryColor}"/>
                                        <TextBlock Text="{Binding CurrentPlayingSongName}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 播放控制 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <!-- 进度条 -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding CurrentPosition, StringFormat='{}{0:mm\\:ss}'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryColor}"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1"
                                                Value="{Binding CurrentPositionSeconds, Mode=TwoWay}"
                                                Maximum="{Binding TotalDurationSeconds}"
                                                Style="{StaticResource ModernSliderStyle}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TotalDuration, StringFormat='{}{0:mm\\:ss}'}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryColor}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- 控制按钮 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Content="⏮"
                                                FontSize="18"
                                                ToolTip="上一首"
                                                Command="{Binding PreviousSongCommand}"
                                                Margin="0,0,8,0"/>
                                        <Button Style="{StaticResource CircleButtonStyle}"
                                                Content="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseConverter}}"
                                                FontSize="16"
                                                ToolTip="播放/暂停"
                                                Command="{Binding PauseSongCommand}"
                                                Margin="0,0,16,0"/>
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Content="⏭"
                                                FontSize="18"
                                                ToolTip="下一首"
                                                Command="{Binding NextSongCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
